# Application Configuration
APP_NAME="RAG Fin"
APP_VERSION="1.0.0"
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
